    }
    
    // Calculate days since first session
    const now = new Date();
    const sessionStartDate = new Date(latestSession.createdAt);
    const daysSinceStart = Math.max(1, Math.floor((now.getTime() - sessionStartDate.getTime()) / (24 * 60 * 60 * 1000)));
    
    // If it's the first day, give a perfect score to encourage engagement
    if (daysSinceStart === 1) return 100;
    
    // Calculate session frequency
    const messagesByDay = new Map();
    sessionMessages.forEach(msg => {
