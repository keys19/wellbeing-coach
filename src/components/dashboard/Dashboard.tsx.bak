"use client";

import { useEffect, useState } from "react";
import { useUser } from "@clerk/nextjs";
import { useRouter } from "next/navigation";
import Link from "next/link";
import { Button } from "@/components/ui/button";
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import { Progress } from "@/components/ui/progress";
import { Tabs, TabsContent, TabsList, TabsTrigger } from "@/components/ui/tabs";
import { ScrollArea } from "@/components/ui/scroll-area";
import {
  ArrowRight,
  Clock,
  Target,
  User,
  BrainCircuit,
  LineChart,
  CheckCircle,
  MessageCircle,
} from "lucide-react";
import { JsonValue } from "@prisma/client/runtime/library";

// Define UserProfile type to match database schema
interface UserProfile {
  id?: string;
  userId?: string;
  age?: number | null;
  gender?: string | null;
  collegeYear?: string | null;
  major?: string | null;
  openMindedness?: number | null;
  conscientiousness?: number | null;
  extraversion?: number | null;
  agreeableness?: number | null;
  neuroticism?: number | null;
  learningStyle?: string | null;
  energyPatterns?: string | null;
  motivationType?: string | null;
  challenges?: Record<string, unknown> | JsonValue | null;
  goals?:
    | {
        mental_health_goals?: Array<{
          description: string;
          measures: string;
          timeframe: string;
          steps: string[];
          obstacles: string[];
          completed: boolean;
          progress?: number;
          lastUpdated?: string;
        }>;
      }
    | JsonValue
    | null;
  commStyle?: Record<string, unknown> | JsonValue | null;
  feedback?: Record<string, unknown> | JsonValue | null;
  hideWelcomeDialog?: boolean | null;
  createdAt?: Date;
  updatedAt?: Date;
}

interface MentalHealthGoal {
  description: string;
  measures: string;
  timeframe: string;
  steps: string[];
  obstacles: string[];
  completed: boolean;
  progress?: number;
  lastUpdated?: string;
}

// Define Session interface
interface Session {
  id: string;
  createdAt: Date;
  userId: string;
  currentPhase?: string;
}

export default function Dashboard() {
  const { user, isLoaded } = useUser();
  const router = useRouter();
  const [userProfile, setUserProfile] = useState<UserProfile | null>(null);
  const [isLoadingProfile, setIsLoadingProfile] = useState(true);
  const [currentDate, setCurrentDate] = useState("");
  // Add state for the latest session
  const [latestSession, setLatestSession] = useState<Session | null>(null);
  const [isLoadingSession, setIsLoadingSession] = useState(true);
  // After the latestSession state, add new states for session messages and highlights
  const [sessionMessages, setSessionMessages] = useState<
    { role: string; content: string }[]
  >([]);
  const [isLoadingSessionMessages, setIsLoadingSessionMessages] =
    useState(true);
  const [recentHighlights, setRecentHighlights] = useState<
    { date: string; content: string }[]
  >([]);

  // Format current date
  useEffect(() => {
    const now = new Date();
    const options: Intl.DateTimeFormatOptions = {
      weekday: "long",
      year: "numeric",
      month: "long",
      day: "numeric",
    };
    setCurrentDate(now.toLocaleDateString("en-US", options));
  }, []);

  // Redirect if not authenticated
  useEffect(() => {
    if (isLoaded && !user) {
      router.push("/sign-in");
    }
  }, [isLoaded, user, router]);

  // Fetch user profile from database
  useEffect(() => {
    async function fetchUserProfile() {
      if (isLoaded && user) {
        try {
          setIsLoadingProfile(true);
          const response = await fetch(`/api/user-profile?userId=${user.id}`);
          if (response.ok) {
            const data = await response.json();
            setUserProfile(data.profile);
          }
        } catch (error) {
          console.error("Error fetching user profile:", error);
        } finally {
          setIsLoadingProfile(false);
        }
      } else if (isLoaded && !user) {
        setIsLoadingProfile(false);
      }
    }

    fetchUserProfile();
  }, [isLoaded, user]);

  // Fetch latest session data
  useEffect(() => {
    async function fetchLatestSession() {
      if (isLoaded && user) {
        try {
          setIsLoadingSession(true);
          const response = await fetch(`/api/sessions?getLatest=true`);
          if (response.ok) {
            const data = await response.json();
            if (data.latestSession) {
              setLatestSession(data.latestSession);
              console.log(
                "Latest session phase:",
                data.latestSession.currentPhase
              );
            }
          }
        } catch (error) {
          console.error("Error fetching latest session:", error);
        } finally {
          setIsLoadingSession(false);
        }
      } else if (isLoaded && !user) {
        setIsLoadingSession(false);
      }
    }

    fetchLatestSession();
  }, [isLoaded, user]);

  // Add function to fetch session messages after the latestSession fetch
  useEffect(() => {
    async function fetchSessionMessages() {
      if (latestSession && latestSession.id) {
        try {
          setIsLoadingSessionMessages(true);
          const response = await fetch(
            `/api/sessions/${latestSession.id}/messages`
          );
          if (response.ok) {
            const data = await response.json();
            if (data.messages && Array.isArray(data.messages)) {
              setSessionMessages(data.messages);

              // Generate highlights from messages
              const extractedHighlights = extractHighlightsFromMessages(
                data.messages,
                latestSession
              );
              setRecentHighlights(extractedHighlights);
            }
          }
        } catch (error) {
          console.error("Error fetching session messages:", error);
        } finally {
          setIsLoadingSessionMessages(false);
        }
      }
    }

    if (!isLoadingSession && latestSession) {
      fetchSessionMessages();
    }
  }, [latestSession, isLoadingSession]);

  // Add a function to extract meaningful highlights from messages
  function extractHighlightsFromMessages(
    messages: { role: string; content: string; createdAt?: string }[],
    session?: Session | null
  ) {
    if (!messages || messages.length === 0) return [];

    const highlights: { date: string; content: string }[] = [];
    const today = new Date();

    // Filter for assistant messages only
    const assistantMessages = messages.filter(
      (msg) => msg.role === "assistant"
    );

    // Get the 3 most recent messages from the assistant
    const recentMessages = assistantMessages.slice(-6);

    // Process messages to extract meaningful content
    for (let i = 0; i < recentMessages.length; i++) {
      if (highlights.length >= 3) break; // Limit to 3 highlights

      const message = recentMessages[i];
      const createdAt = message.createdAt
        ? new Date(message.createdAt)
        : new Date(today.getTime() - i * 86400000); // If no date, use today minus i days

      // Clean the message content
      let content = message.content
        // Remove phase markers
        .replace(/\[(?:Phase|PHASE) \d+\]/g, "")
        .replace(
          /\[(?:ONGOING|EXPLORATION|ACTION_PLANNING|GOAL_SETTING|INTRODUCTION)_PHASE\]/g,
          ""
        )
        // Remove JSON
        .replace(/```json[\s\S]*?```/g, "")
        // Remove profile summaries
        .replace(
          /Here's what I know about you so far:[\s\S]*?(Let's|Now|I'll|Moving)/i,
          "$1"
        )
        .replace(
          /Based on our conversation, I've learned that:[\s\S]*?(Let's|Now|I'll|Moving)/i,
          "$1"
        )
        .replace(
          /Based on our conversation so far,[\s\S]*?(Let's|Now|I'll|Moving)/i,
          "$1"
        );

      // Extract meaningful sentences
      const sentences = content.split(/[.!?]\s+/);
      const meaningfulSentences = sentences.filter((sentence) => {
        const words = sentence.trim().split(/\s+/).length;
        // Select sentences that mention progress, techniques, concepts, or are 8-20 words long
        return (
          words >= 8 &&
          words <= 30 &&
          (sentence.includes("progress") ||
            sentence.includes("anxiety") ||
            sentence.includes("stress") ||
            sentence.includes("techniques") ||
            sentence.includes("skills") ||
            sentence.includes("manage") ||
            sentence.includes("improve") ||
            sentence.includes("goal"))
        );
      });

      // If we have meaningful sentences, create a highlight
      if (meaningfulSentences.length > 0) {
        const highlightContent = meaningfulSentences[0].trim() + ".";
        highlights.push({
          date: createdAt.toLocaleDateString("en-US", {
            month: "long",
            day: "numeric",
            year: "numeric",
          }),
          content: highlightContent,
        });
      }
    }

    // If we couldn't extract enough highlights, add some general ones
    if (highlights.length === 0 && session) {
      const sessionDate = new Date(session.createdAt);

      // Add phase-specific highlights based on the current phase
      if (
        session.currentPhase === "introduction" ||
        session.currentPhase === "exploration"
      ) {
        highlights.push({
          date: sessionDate.toLocaleDateString("en-US", {
            month: "long",
            day: "numeric",
            year: "numeric",
          }),
          content:
            "We're getting to know your needs and challenges. We've started exploring techniques to help manage your specific situation.",
        });
      } else if (session.currentPhase === "goal_setting") {
        highlights.push({
          date: sessionDate.toLocaleDateString("en-US", {
            month: "long",
            day: "numeric",
            year: "numeric",
          }),
          content:
            "We've identified key areas to focus on and begun setting SMART goals to guide your mental health journey.",
        });
      } else if (
        session.currentPhase === "action_planning" ||
        session.currentPhase === "ongoing_conversation"
      ) {
        highlights.push({
          date: sessionDate.toLocaleDateString("en-US", {
            month: "long",
            day: "numeric",
            year: "numeric",
          }),
          content:
            "You're making progress implementing action steps toward your goals. Breaking tasks into smaller steps is helping reduce anxiety.",
        });
      }
    }

    return highlights;
  }

  // Replace the getSessionHighlights function with this:
