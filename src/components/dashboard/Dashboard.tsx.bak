"use client";

import { useEffect, useState } from "react";
import { useUser } from "@clerk/nextjs";
import { useRouter } from "next/navigation";
import Link from "next/link";
import { Button } from "@/components/ui/button";
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import { Progress } from "@/components/ui/progress";
import { Tabs, TabsContent, TabsList, TabsTrigger } from "@/components/ui/tabs";
import { ScrollArea } from "@/components/ui/scroll-area";
import {
  ArrowRight,
  Clock,
  Target,
  User,
  BrainCircuit,
  LineChart,
  CheckCircle,
  MessageCircle,
} from "lucide-react";
import { JsonValue } from "@prisma/client/runtime/library";

// Define UserProfile type to match database schema
interface UserProfile {
  id?: string;
  userId?: string;
  age?: number | null;
  gender?: string | null;
  collegeYear?: string | null;
  major?: string | null;
  openMindedness?: number | null;
  conscientiousness?: number | null;
  extraversion?: number | null;
  agreeableness?: number | null;
  neuroticism?: number | null;
  learningStyle?: string | null;
  energyPatterns?: string | null;
  motivationType?: string | null;
  challenges?: Record<string, unknown> | JsonValue | null;
  goals?:
    | {
        mental_health_goals?: Array<{
          description: string;
          measures: string;
          timeframe: string;
          steps: string[];
          obstacles: string[];
          completed: boolean;
          progress?: number;
          lastUpdated?: string;
        }>;
      }
    | JsonValue
    | null;
  commStyle?: Record<string, unknown> | JsonValue | null;
  feedback?: Record<string, unknown> | JsonValue | null;
  hideWelcomeDialog?: boolean | null;
  createdAt?: Date;
  updatedAt?: Date;
}

interface MentalHealthGoal {
  description: string;
  measures: string;
  timeframe: string;
  steps: string[];
  obstacles: string[];
  completed: boolean;
  progress?: number;
  lastUpdated?: string;
}

// Define Session interface
interface Session {
  id: string;
  createdAt: Date;
  userId: string;
  currentPhase?: string;
}

export default function Dashboard() {
  const { user, isLoaded } = useUser();
  const router = useRouter();
  const [userProfile, setUserProfile] = useState<UserProfile | null>(null);
  const [isLoadingProfile, setIsLoadingProfile] = useState(true);
  const [currentDate, setCurrentDate] = useState("");
  // Add state for the latest session
  const [latestSession, setLatestSession] = useState<Session | null>(null);
  const [isLoadingSession, setIsLoadingSession] = useState(true);
  // After the latestSession state, add new states for session messages and highlights
  const [sessionMessages, setSessionMessages] = useState<
    { role: string; content: string }[]
  >([]);
  const [isLoadingSessionMessages, setIsLoadingSessionMessages] =
    useState(true);
  const [recentHighlights, setRecentHighlights] = useState<
    { date: string; content: string }[]
  >([]);

  // Format current date
  useEffect(() => {
    const now = new Date();
    const options: Intl.DateTimeFormatOptions = {
      weekday: "long",
      year: "numeric",
      month: "long",
      day: "numeric",
    };
    setCurrentDate(now.toLocaleDateString("en-US", options));
  }, []);

  // Redirect if not authenticated
  useEffect(() => {
    if (isLoaded && !user) {
      router.push("/sign-in");
    }
  }, [isLoaded, user, router]);

  // Fetch user profile from database
  useEffect(() => {
    async function fetchUserProfile() {
      if (isLoaded && user) {
        try {
          setIsLoadingProfile(true);
          const response = await fetch(`/api/user-profile?userId=${user.id}`);
          if (response.ok) {
            const data = await response.json();
            setUserProfile(data.profile);
          }
        } catch (error) {
          console.error("Error fetching user profile:", error);
        } finally {
          setIsLoadingProfile(false);
        }
      } else if (isLoaded && !user) {
        setIsLoadingProfile(false);
      }
    }

    fetchUserProfile();
  }, [isLoaded, user]);

  // Fetch latest session data
  useEffect(() => {
    async function fetchLatestSession() {
      if (isLoaded && user) {
        try {
          setIsLoadingSession(true);
          const response = await fetch(`/api/sessions?getLatest=true`);
          if (response.ok) {
            const data = await response.json();
            if (data.latestSession) {
              setLatestSession(data.latestSession);
              console.log(
                "Latest session phase:",
                data.latestSession.currentPhase
              );
            }
          }
        } catch (error) {
          console.error("Error fetching latest session:", error);
        } finally {
          setIsLoadingSession(false);
        }
      } else if (isLoaded && !user) {
        setIsLoadingSession(false);
      }
    }

    fetchLatestSession();
  }, [isLoaded, user]);

  // Add function to fetch session messages after the latestSession fetch
  useEffect(() => {
    async function fetchSessionMessages() {
      if (latestSession && latestSession.id) {
        try {
          setIsLoadingSessionMessages(true);
          const response = await fetch(
            `/api/sessions/${latestSession.id}/messages`
          );
          if (response.ok) {
            const data = await response.json();
            if (data.messages && Array.isArray(data.messages)) {
              setSessionMessages(data.messages);

              // Generate highlights from messages
              const extractedHighlights = extractHighlightsFromMessages(
                data.messages,
                latestSession
              );
              setRecentHighlights(extractedHighlights);
            }
          }
        } catch (error) {
          console.error("Error fetching session messages:", error);
        } finally {
          setIsLoadingSessionMessages(false);
        }
      }
    }

    if (!isLoadingSession && latestSession) {
      fetchSessionMessages();
    }
  }, [latestSession, isLoadingSession]);

  // Add a function to extract meaningful highlights from messages
  function extractHighlightsFromMessages(
    messages: { role: string; content: string; createdAt?: string }[],
    session?: Session | null
  ) {
    if (!messages || messages.length === 0) return [];

    const highlights: { date: string; content: string }[] = [];
    const today = new Date();

    // Filter for assistant messages only
    const assistantMessages = messages.filter(
      (msg) => msg.role === "assistant"
    );

    // Get the 3 most recent messages from the assistant
    const recentMessages = assistantMessages.slice(-6);

    // Process messages to extract meaningful content
    for (let i = 0; i < recentMessages.length; i++) {
      if (highlights.length >= 3) break; // Limit to 3 highlights

      const message = recentMessages[i];
      const createdAt = message.createdAt
        ? new Date(message.createdAt)
        : new Date(today.getTime() - i * 86400000); // If no date, use today minus i days

      // Clean the message content
      let content = message.content
        // Remove phase markers
        .replace(/\[(?:Phase|PHASE) \d+\]/g, "")
        .replace(
          /\[(?:ONGOING|EXPLORATION|ACTION_PLANNING|GOAL_SETTING|INTRODUCTION)_PHASE\]/g,
          ""
        )
        // Remove JSON
        .replace(/```json[\s\S]*?```/g, "")
        // Remove profile summaries
        .replace(
          /Here's what I know about you so far:[\s\S]*?(Let's|Now|I'll|Moving)/i,
          "$1"
        )
        .replace(
          /Based on our conversation, I've learned that:[\s\S]*?(Let's|Now|I'll|Moving)/i,
          "$1"
        )
        .replace(
          /Based on our conversation so far,[\s\S]*?(Let's|Now|I'll|Moving)/i,
          "$1"
        );

      // Extract meaningful sentences
      const sentences = content.split(/[.!?]\s+/);
      const meaningfulSentences = sentences.filter((sentence) => {
        const words = sentence.trim().split(/\s+/).length;
        // Select sentences that mention progress, techniques, concepts, or are 8-20 words long
        return (
          words >= 8 &&
          words <= 30 &&
          (sentence.includes("progress") ||
            sentence.includes("anxiety") ||
            sentence.includes("stress") ||
            sentence.includes("techniques") ||
            sentence.includes("skills") ||
            sentence.includes("manage") ||
            sentence.includes("improve") ||
            sentence.includes("goal"))
        );
      });

      // If we have meaningful sentences, create a highlight
      if (meaningfulSentences.length > 0) {
        const highlightContent = meaningfulSentences[0].trim() + ".";
        highlights.push({
          date: createdAt.toLocaleDateString("en-US", {
            month: "long",
            day: "numeric",
            year: "numeric",
          }),
          content: highlightContent,
        });
      }
    }

    // If we couldn't extract enough highlights, add some general ones
    if (highlights.length === 0 && session) {
      const sessionDate = new Date(session.createdAt);

      // Add phase-specific highlights based on the current phase
      if (
        session.currentPhase === "introduction" ||
        session.currentPhase === "exploration"
      ) {
        highlights.push({
          date: sessionDate.toLocaleDateString("en-US", {
            month: "long",
            day: "numeric",
            year: "numeric",
          }),
          content:
            "We're getting to know your needs and challenges. We've started exploring techniques to help manage your specific situation.",
        });
      } else if (session.currentPhase === "goal_setting") {
        highlights.push({
          date: sessionDate.toLocaleDateString("en-US", {
            month: "long",
            day: "numeric",
            year: "numeric",
          }),
          content:
            "We've identified key areas to focus on and begun setting SMART goals to guide your mental health journey.",
        });
      } else if (
        session.currentPhase === "action_planning" ||
        session.currentPhase === "ongoing_conversation"
      ) {
        highlights.push({
          date: sessionDate.toLocaleDateString("en-US", {
            month: "long",
            day: "numeric",
            year: "numeric",
          }),
          content:
            "You're making progress implementing action steps toward your goals. Breaking tasks into smaller steps is helping reduce anxiety.",
        });
      }
    }

    return highlights;
  }

  // Replace the getSessionHighlights function with this:
  const getSessionHighlights = () => {
    // If we have extracted real highlights, use those
    if (recentHighlights.length > 0) {
      return recentHighlights;
    }

    // Check if we have at least some data in the profile to generate insights
    const hasProfileData =
      userProfile &&
      (userProfile.openMindedness !== null ||
        userProfile.challenges !== null ||
        userProfile.goals !== null);

    // If we don't have enough data, return an empty array
    if (!hasProfileData) {
      return [];
    }

    // Return generic highlights as fallback
    return [
      {
        date: new Date().toLocaleDateString("en-US", {
          month: "long",
          day: "numeric",
          year: "numeric",
        }),
        content:
          "You're currently in the ongoing phase of your mental health journey. Managing anxiety when taking on new tasks by viewing them as learning opportunities shows progress.",
      },
      {
        date: new Date(Date.now() - 2 * 24 * 60 * 60 * 1000).toLocaleDateString(
          "en-US",
          { month: "long", day: "numeric", year: "numeric" }
        ),
        content:
          "We identified that breaking tasks into smaller steps helps reduce your anxiety. You've shown consistent improvement in applying this technique.",
      },
      {
        date: new Date(Date.now() - 6 * 24 * 60 * 60 * 1000).toLocaleDateString(
          "en-US",
          { month: "long", day: "numeric", year: "numeric" }
        ),
        content:
          "You've begun implementing the mindfulness exercises we discussed. Your self-reports indicate reduced stress levels when using these techniques.",
      },
    ];
  };

  // Get session highlights based on user profile
  const sessionHighlights = getSessionHighlights();

  // Extract current phase information for dashboard display
  const determineCurrentPhase = () => {
    // First check if we have a valid session with phase information
    if (latestSession && latestSession.currentPhase) {
      const phase = latestSession.currentPhase;

      // Map phase to progress value
      let progress = 20;
      if (phase === "exploration") progress = 60;
      if (phase === "goal_setting") progress = 60;
      if (phase === "action_planning") progress = 100;
      if (phase === "ongoing_conversation") progress = 100;

      return { phase, progress };
    }

    // Fallback to profile-based phase determination
    if (!userProfile) return { phase: "introduction", progress: 20 };

    // Check if we have session data available
    const phase = userProfile.goals
      ? { phase: "action_planning", progress: 100 }
      : userProfile.challenges
      ? { phase: "exploration", progress: 60 }
      : { phase: "introduction", progress: 20 };

    return phase;
  };

  const currentPhase = determineCurrentPhase();

  if (
    !isLoaded ||
    isLoadingProfile ||
    isLoadingSession ||
    isLoadingSessionMessages
  ) {
    return (
      <div className="container mx-auto px-4 py-6 relative">
        {/* Muddy overlay effect */}
        <div className="absolute inset-0 bg-background/80 backdrop-blur-sm z-10"></div>

        {/* Dashboard skeleton content */}
        <div className="relative opacity-70 pointer-events-none">
          {/* Header Section with Journey Progress */}
          <div className="mb-8 bg-gradient-to-r from-indigo-600 via-purple-600 to-purple-700 text-white rounded-xl p-6 shadow-lg">
            <div className="flex flex-col md:flex-row justify-between items-start md:items-center mb-4">
              <div>
                <h1 className="text-3xl font-bold">
                  Your Mental Health Journey
                </h1>
                <p className="text-indigo-100">Personal Dashboard</p>
              </div>
              <div className="mt-2 md:mt-0 text-right">
                <div className="inline-flex items-center px-3 py-1 rounded-full bg-white/10 backdrop-blur-sm">
                  <Clock className="h-4 w-4 mr-2 text-indigo-200" />
                  <p className="text-sm text-indigo-100">
                    {currentDate || "Loading date..."}
                  </p>
                </div>
              </div>
            </div>
          </div>

          {/* Progress Overview - Skeleton Cards */}
          <h2 className="text-2xl font-bold mb-4 flex items-center gap-2">
            <div className="w-1 h-6 bg-indigo-600 rounded-full mr-1"></div>
            Progress Overview
          </h2>
          <div className="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            {[1, 2, 3].map((i) => (
              <Card
                key={i}
                className="overflow-hidden transition-all border-t-4 border-t-indigo-500/50"
              >
                <CardHeader className="pb-2">
                  <div className="h-6 w-3/4 bg-muted rounded-md"></div>
                </CardHeader>
                <CardContent>
                  <div className="h-8 w-1/4 bg-muted rounded-md mb-2"></div>
                  <div className="h-3 w-full bg-muted rounded-full"></div>
                </CardContent>
              </Card>
            ))}
          </div>
        </div>
      </div>
    );
  }

  if (!user) {
    return null; // Router will redirect
  }

  // Calculate progress percentages (mock data if not available)
  const overallProgress = 65; // Mock progress
  const emotionalWellbeing = 75; // Mock wellbeing score
  const consistency = 80; // Mock consistency score

  // Extract personality traits or use defaults
  // Convert decimal values (0.5) to percentages (50) by multiplying by 100
  const personalityTraits = {
    openMindedness: userProfile?.openMindedness
      ? Math.round(userProfile.openMindedness * 100)
      : 60,
    conscientiousness: userProfile?.conscientiousness
      ? Math.round(userProfile.conscientiousness * 100)
      : 75,
    extraversion: userProfile?.extraversion
      ? Math.round(userProfile.extraversion * 100)
      : 45,
    agreeableness: userProfile?.agreeableness
      ? Math.round(userProfile.agreeableness * 100)
      : 80,
    neuroticism: userProfile?.neuroticism
      ? Math.round(userProfile.neuroticism * 100)
      : 30,
  };

  // Generate goals from user profile
  const getGoalsFromProfile = (profile: UserProfile | null) => {
    if (!profile?.goals || typeof profile.goals !== "object") {
      return [];
    }

    const goalsData = profile.goals as {
      mental_health_goals?: MentalHealthGoal[];
    };
    if (!goalsData.mental_health_goals) {
      return [];
    }

    return goalsData.mental_health_goals.map((goal, index) => ({
      id: index + 1,
      title: goal.description,
      target: goal.timeframe,
      progress: goal.progress || calculateProgress(goal.timeframe),
      lastUpdated: goal.lastUpdated || new Date().toLocaleDateString(),
      completed: goal.completed || false,
    }));
  };

  // Calculate progress based on timeframe
  const calculateProgress = (timeframe: string) => {
    try {
      const match = timeframe.match(/(\d+)\s+weeks?\s+from\s+(.+)/i);
      if (!match) return 0;

      const weeks = parseInt(match[1]);
      const startDate = new Date(match[2]);
      const endDate = new Date(
        startDate.getTime() + weeks * 7 * 24 * 60 * 60 * 1000
      );
      const now = new Date();

      if (now >= endDate) return 100;
      if (now <= startDate) return 0;

      const totalDuration = endDate.getTime() - startDate.getTime();
      const elapsed = now.getTime() - startDate.getTime();
      return Math.round((elapsed / totalDuration) * 100);
    } catch (error) {
      console.error("Error calculating progress:", error);
      return 0;
    }
  };

  // Replace mock goals with real goals from profile
  const goals = getGoalsFromProfile(userProfile);

  // Replace the above mock calculations with real functions

  // Calculate actual progress metrics based on real data
  const calculateOverallProgress = (goals: any[]) => {
    if (!goals || goals.length === 0) return 30; // Default starting value
    
    // Get total progress across all goals
    const totalProgress = goals.reduce((sum, goal) => sum + (goal.progress || 0), 0);
    
    // Calculate average progress
    return Math.round(totalProgress / goals.length);
  };

  const calculateEmotionalWellbeing = (messages: any[], userProfile: UserProfile | null) => {
    // Start with a baseline score
    let baseScore = 60;
    
    // If we have no data yet, return the baseline
    if ((!messages || messages.length < 5) && (!userProfile || !userProfile.openMindedness)) {
      return baseScore;
    }
    
    // Use personality traits if available to adjust the score
    if (userProfile) {
      // High conscientiousness and low neuroticism typically correlate with better emotional wellbeing
      if (userProfile.conscientiousness !== null && userProfile.neuroticism !== null) {
        const conscientScore = (userProfile.conscientiousness || 0.5) * 100;
        const neuroticismScore = (userProfile.neuroticism || 0.5) * 100;
        
        // Weighted formula: higher conscientiousness boosts score, higher neuroticism reduces it
        baseScore = Math.round(baseScore + (conscientScore * 0.2) - (neuroticismScore * 0.2));
      }
    }
    
    // Analyze recent messages for sentiment indicators
    if (messages && messages.length > 0) {
      // Look at recent user messages for emotional language
      const userMessages = messages
        .filter(msg => msg.role === 'user')
        .slice(-10);
      
      const positiveWords = ['good', 'better', 'happy', 'progress', 'improve', 'calm', 'relax', 'achieve'];
      const negativeWords = ['stress', 'anxiety', 'worried', 'sad', 'overwhelm', 'difficult', 'struggle', 'bad'];
      
      let positiveCount = 0;
      let negativeCount = 0;
      
      // Count sentiment indicators in messages
      userMessages.forEach(msg => {
        const content = msg.content.toLowerCase();
        positiveWords.forEach(word => {
          if (content.includes(word)) positiveCount++;
        });
        negativeWords.forEach(word => {
          if (content.includes(word)) negativeCount++;
        });
      });
      
      // Adjust score based on sentiment analysis
      if (positiveCount + negativeCount > 0) {
        const sentimentImpact = 15; // Maximum impact of sentiment analysis
        const sentimentRatio = positiveCount / (positiveCount + negativeCount);
        baseScore = Math.round(baseScore + ((sentimentRatio - 0.5) * sentimentImpact * 2));
      }
    }
    
    // Ensure score stays within 0-100 range
    return Math.max(0, Math.min(100, baseScore));
  };

  const calculateConsistency = (sessionMessages: any[], latestSession: Session | null) => {
    // Default consistency value for new users
    const defaultConsistency = 50;
    
    // If we don't have a session or messages, return default
    if (!latestSession || !sessionMessages || sessionMessages.length === 0) {
      return defaultConsistency;
    }
    
    // Calculate days since first session
    const now = new Date();
    const sessionStartDate = new Date(latestSession.createdAt);
    const daysSinceStart = Math.max(1, Math.floor((now.getTime() - sessionStartDate.getTime()) / (24 * 60 * 60 * 1000)));
    
    // If it's the first day, give a perfect score to encourage engagement
    if (daysSinceStart === 1) return 100;
    
    // Calculate session frequency
    const messagesByDay = new Map();
    sessionMessages.forEach(msg => {
      if (msg.createdAt) {
        const date = new Date(msg.createdAt).toDateString();
        messagesByDay.set(date, (messagesByDay.get(date) || 0) + 1);
      }
    });
    
    // Count days with activity
    const daysActive = messagesByDay.size;
    
    // For very new users (less than a week), use a different scaling
    if (daysSinceStart < 7) {
      return Math.round((daysActive / daysSinceStart) * 100);
    }
    
    // For established users, use a weighted score
    // Consider message count and message length as factors
    
    // Calculate average messages per active day
    const totalMessages = sessionMessages.length;
    const avgMessagesPerDay = totalMessages / daysActive;
    
    // Quality of engagement: boost score for days with 5+ messages
    const engagementQuality = Array.from(messagesByDay.values()).filter(count => count >= 5).length / daysActive;
    
    // Consistency formula: balance between frequency of check-ins and quality of engagement
    const frequencyScore = (daysActive / Math.min(daysSinceStart, 14)) * 80; // Cap at 2 weeks for frequency calculation
    const qualityBonus = engagementQuality * 20; // Up to 20% boost for high-quality engagements
    
    // Final score, ensuring it's between 0-100
    return Math.max(0, Math.min(100, Math.round(frequencyScore + qualityBonus)));
  };

  // Apply the calculations with real data
  const overallProgress = calculateOverallProgress(goals);
  const emotionalWellbeing = calculateEmotionalWellbeing(sessionMessages, userProfile);
  const consistency = calculateConsistency(sessionMessages, latestSession);

  // Extract personality traits or use defaults
  // Convert decimal values (0.5) to percentages (50) by multiplying by 100

  // Calculate progress percentages (mock data if not available)
  const overallProgress = 65; // Mock progress
  const emotionalWellbeing = 75; // Mock wellbeing score
  const consistency = 80; // Mock consistency score

  // Extract personality traits or use defaults
  // Convert decimal values (0.5) to percentages (50) by multiplying by 100

  // Replace mock calculations with real functions

  // Calculate actual progress metrics based on real data
  const calculateOverallProgress = (goals: any[]) => {
    if (!goals || goals.length === 0) return 30; // Default starting value
    
    // Get total progress across all goals
    const totalProgress = goals.reduce((sum, goal) => sum + (goal.progress || 0), 0);
    
    // Calculate average progress
    return Math.round(totalProgress / goals.length);
  };

  const calculateEmotionalWellbeing = (messages: any[], userProfile: UserProfile | null) => {
    // Start with a baseline score
    let baseScore = 60;
    
    // If we have no data yet, return the baseline
    if ((!messages || messages.length < 5) && (!userProfile || !userProfile.openMindedness)) {
      return baseScore;
    }
    
    // Use personality traits if available to adjust the score
    if (userProfile) {
      // High conscientiousness and low neuroticism typically correlate with better emotional wellbeing
      if (userProfile.conscientiousness !== null && userProfile.neuroticism !== null) {
        const conscientScore = (userProfile.conscientiousness || 0.5) * 100;
        const neuroticismScore = (userProfile.neuroticism || 0.5) * 100;
        
        // Weighted formula: higher conscientiousness boosts score, higher neuroticism reduces it
        baseScore = Math.round(baseScore + (conscientScore * 0.2) - (neuroticismScore * 0.2));
      }
    }
    
    // Analyze recent messages for sentiment indicators
    if (messages && messages.length > 0) {
      // Look at recent user messages for emotional language
      const userMessages = messages
        .filter(msg => msg.role === 'user')
        .slice(-10);
      
      const positiveWords = ['good', 'better', 'happy', 'progress', 'improve', 'calm', 'relax', 'achieve'];
      const negativeWords = ['stress', 'anxiety', 'worried', 'sad', 'overwhelm', 'difficult', 'struggle', 'bad'];
      
      let positiveCount = 0;
      let negativeCount = 0;
      
      // Count sentiment indicators in messages
      userMessages.forEach(msg => {
        const content = msg.content.toLowerCase();
        positiveWords.forEach(word => {
          if (content.includes(word)) positiveCount++;
        });
        negativeWords.forEach(word => {
          if (content.includes(word)) negativeCount++;
        });
      });
      
      // Adjust score based on sentiment analysis
      if (positiveCount + negativeCount > 0) {
        const sentimentImpact = 15; // Maximum impact of sentiment analysis
        const sentimentRatio = positiveCount / (positiveCount + negativeCount);
        baseScore = Math.round(baseScore + ((sentimentRatio - 0.5) * sentimentImpact * 2));
      }
    }
    
    // Ensure score stays within 0-100 range
    return Math.max(0, Math.min(100, baseScore));
  };

  const calculateConsistency = (sessionMessages: any[], latestSession: Session | null) => {
    // Default consistency value for new users
    const defaultConsistency = 50;
    
    // If we don't have a session or messages, return default
    if (!latestSession || !sessionMessages || sessionMessages.length === 0) {
      return defaultConsistency;
    }
    
    // Calculate days since first session
    const now = new Date();
    const sessionStartDate = new Date(latestSession.createdAt);
    const daysSinceStart = Math.max(1, Math.floor((now.getTime() - sessionStartDate.getTime()) / (24 * 60 * 60 * 1000)));
    
    // If it's the first day, give a perfect score to encourage engagement
    if (daysSinceStart === 1) return 100;
    
    // Calculate session frequency
    const messagesByDay = new Map();
    sessionMessages.forEach(msg => {
      if (msg.createdAt) {
