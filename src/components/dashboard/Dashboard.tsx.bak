      // High conscientiousness and low neuroticism typically correlate with better emotional wellbeing
      if (userProfile.conscientiousness !== null && userProfile.neuroticism !== null) {
        const conscientScore = (userProfile.conscientiousness || 0.5) * 100;
        const neuroticismScore = (userProfile.neuroticism || 0.5) * 100;
        
